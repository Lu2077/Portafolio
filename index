<!--<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Harsh Patil Portfolio website</title>
    <meta name="description" content="Harshawardhan Patil — Robotics · AI · Autonomous Driving Engineer, Stuttgart Germany.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@300;400;500&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    
    <script>
        const savedTheme = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const initialTheme = savedTheme ? savedTheme : (systemDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', initialTheme);
    </script>

    <style>

        :root[data-theme="dark"] {
            --bg: #050510;
            --bg2: #0b0b1f;
            --bg3: #10102a;
            --surface: rgba(255, 255, 255, .04);
            --surface2: rgba(255, 255, 255, .07);
            --border: rgba(255, 255, 255, .08);
            --border2: rgba(255, 255, 255, .15);
            --text: #e8e8f0;
            --text2: #9090b0;
            --text3: #5a5a7a;
            --accent: #f97316;
            --accent2: #38bdf8;
            --accent3: #a78bfa;
            --glow: rgba(249, 115, 22, .3);
            --glow2: rgba(56, 189, 248, .2);
            --ps: rgba(255, 255, 255, .13);
        }

        :root[data-theme="light"] {
            --bg: #fff;
            --bg2: #fff7ed;
            --bg3: #fff;
            --surface: rgba(249, 115, 22, .05);
            --surface2: rgba(249, 115, 22, .1);
            --border: rgba(249, 115, 22, .15);
            --border2: rgba(249, 115, 22, .3);
            --text: #1a0a00;
            --text2: #6b3a1f;
            --text3: #9a7a6a;
            --accent: #ea580c;
            --accent2: #0284c7;
            --accent3: #7c3aed;
            --glow: rgba(234, 88, 12, .3);
            --glow2: rgba(2, 132, 199, .25);
            --ps: rgba(234, 88, 12, .2);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: "Instrument Sans", sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            transition: background .4s, color .4s;
        }

        #starfield {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
        }

        #planets {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        #planets svg {
            position: absolute;
        }

        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            padding: 0 4%;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            background: rgba(5, 5, 16, .75);
            border-bottom: 1px solid var(--border);
            transition: background .4s;
            overflow: hidden;
        }

        [data-theme="light"] body {
            background: #fff;
        }

        [data-theme="light"] body::before {
            content: "";
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background: radial-gradient(ellipse 90% 70% at 5% 0%, rgba(249, 115, 22, .5) 0%, transparent 55%), 
                        radial-gradient(ellipse 70% 60% at 95% 5%, rgba(56, 189, 248, .4) 0%, transparent 50%), 
                        radial-gradient(ellipse 60% 50% at 85% 95%, rgba(167, 139, 250, .35) 0%, transparent 50%);
            animation: meshshift 12s ease-in-out infinite alternate;
        }

        @keyframes meshshift {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: .88; transform: scale(1.03); }
            100% { opacity: 1; transform: scale(1); }
        }

        [data-theme="light"] #starfield {
            opacity: 0;
        }

        [data-theme="light"] nav {
            background: rgba(255, 255, 255, .8);
            border-bottom: 1px solid rgba(234, 88, 12, .15);
        }

        [data-theme="light"] .stat-num {
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        [data-theme="light"] .section-label {
            background: linear-gradient(90deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        [data-theme="light"] .section-label::after {
            background: linear-gradient(to right, var(--accent), var(--accent2));
            opacity: .6;
        }

        [data-theme="light"] .hero-name .last {
            -webkit-text-stroke-color: var(--accent);
        }

        [data-theme="light"] .hero-name .first {
            background: linear-gradient(135deg, #ea580c, #0284c7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        [data-theme="light"] .orb1 {
            border-color: rgba(234, 88, 12, .25);
        }

        [data-theme="light"] .orb2 {
            border-color: rgba(2, 132, 199, .2);
        }

        [data-theme="light"] .orb1::before {
            background: #ea580c;
            box-shadow: 0 0 20px rgba(234, 88, 12, .7);
        }

        [data-theme="light"] .orb2::before {
            background: #0284c7;
            box-shadow: 0 0 20px rgba(2, 132, 199, .7);
        }

        [data-theme="light"] .sg {
            background: #fff;
            border: 1px solid rgba(234, 88, 12, .15);
            box-shadow: 0 2px 16px rgba(234, 88, 12, .07);
            border-left: 3px solid var(--accent);
        }

        [data-theme="light"] .sg:hover {
            border-left-color: var(--accent2);
            box-shadow: 0 8px 32px rgba(234, 88, 12, .15);
            transform: translateY(-4px);
        }

        [data-theme="light"] .tag {
            background: linear-gradient(135deg, rgba(234, 88, 12, .08), rgba(2, 132, 199, .06));
            border-color: rgba(234, 88, 12, .2);
            color: var(--text2);
        }

        [data-theme="light"] .tag:hover {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

        [data-theme="light"] .pcard {
            border: 1px solid rgba(234, 88, 12, .15);
            background: #fff;
            box-shadow: 0 4px 20px rgba(234, 88, 12, .07);
        }

        [data-theme="light"] .pcard:hover {
            border-color: var(--accent);
            box-shadow: 0 12px 40px rgba(234, 88, 12, .18);
        }

        [data-theme="light"] .pcard::after {
            background: linear-gradient(to right, #ea580c, #0284c7, #7c3aed);
        }

        [data-theme="light"] .edu-card {
            border: 1px solid rgba(2, 132, 199, .2);
            background: #fff;
            box-shadow: 0 4px 20px rgba(2, 132, 199, .07);
            border-top: 3px solid var(--accent2);
        }

        [data-theme="light"] .edu-card:hover {
            border-color: var(--accent2);
            box-shadow: 0 12px 40px rgba(2, 132, 199, .16);
        }

        [data-theme="light"] .citem-icon {
            background: #fff;
            border: 2px solid rgba(234, 88, 12, .2);
            box-shadow: 0 4px 16px rgba(234, 88, 12, .08);
        }

        [data-theme="light"] .citem-icon:hover {
            background: linear-gradient(135deg, rgba(234, 88, 12, .08), rgba(2, 132, 199, .08));
            border-color: var(--accent);
            box-shadow: 0 8px 28px rgba(234, 88, 12, .2);
        }

        [data-theme="light"] .resume-banner {
            background: linear-gradient(135deg, rgba(234, 88, 12, .07), rgba(2, 132, 199, .07));
            border: 1px solid rgba(234, 88, 12, .2);
        }

        [data-theme="light"] .section-divider {
            background: linear-gradient(to right, transparent, rgba(234, 88, 12, .25), rgba(2, 132, 199, .15), transparent);
        }

        [data-theme="light"] .btn-primary {
            background: linear-gradient(135deg, #ea580c, #0284c7);
            border: none;
            box-shadow: 0 6px 24px rgba(234, 88, 12, .35);
        }

        [data-theme="light"] .btn-primary:hover {
            box-shadow: 0 10px 36px rgba(234, 88, 12, .45);
            transform: translateY(-3px);
        }

        [data-theme="light"] .btn-ghost {
            border-color: rgba(234, 88, 12, .3);
            color: var(--accent);
        }

        [data-theme="light"] .btn-ghost:hover {
            background: rgba(234, 88, 12, .06);
            border-color: var(--accent);
        }

        [data-theme="light"] .btn-resume {
            border-color: var(--accent2);
            color: var(--accent2);
            box-shadow: 0 4px 16px rgba(2, 132, 199, .2);
        }

        [data-theme="light"] .avatar-initials {
            background: linear-gradient(135deg, #fff, #fff7ed);
            box-shadow: 0 0 60px rgba(234, 88, 12, .25);
        }

        [data-theme="light"] .avatar-ring {
            border-color: rgba(234, 88, 12, .3);
        }

        [data-theme="light"] .avatar-ring::before {
            border-color: rgba(2, 132, 199, .25);
        }

        [data-theme="light"] .avatar-ring::after {
            border-top-color: var(--accent);
        }

        [data-theme="light"] .scroll-line {
            background: linear-gradient(to bottom, #ea580c, #0284c7, transparent);
        }

        [data-theme="light"] .planet-popup {
            background: #fff;
            border-color: rgba(234, 88, 12, .25);
            box-shadow: 0 12px 40px rgba(234, 88, 12, .15);
        }

        [data-theme="light"] .picon {
            background: linear-gradient(135deg, rgba(234, 88, 12, .08), rgba(2, 132, 199, .08));
            border-color: rgba(234, 88, 12, .2);
        }

        .nav-logo {
            font-family: "Syne", sans-serif;
            font-weight: 800;
            font-size: 1.1rem;
            letter-spacing: -.02em;
            color: var(--text);
            text-decoration: none;
        }

        .nav-logo span {
            color: var(--accent);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 1.4rem;
            list-style: none;
            flex-shrink: 0;
        }

        .nav-links a {
            font-family: "DM Mono", monospace;
            font-size: .68rem;
            color: var(--text2);
            text-decoration: none;
            letter-spacing: .06em;
            text-transform: uppercase;
            transition: color .2s;
            white-space: nowrap;
        }

        .nav-links a:hover {
            color: var(--accent);
        }

        .theme-btn {
            background: var(--surface2);
            border: 1px solid var(--border2);
            border-radius: 20px;
            padding: 5px 12px;
            cursor: pointer;
            font-family: "DM Mono", monospace;
            font-size: .68rem;
            color: var(--text2);
            display: flex;
            align-items: center;
            gap: 5px;
            transition: all .2s;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .theme-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 4px;
        }

        .hamburger span {
            width: 22px;
            height: 1.5px;
            background: var(--text2);
            display: block;
        }

        #hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 80px 5% 60px;
            z-index: 2;
        }

        .hero-eyebrow {
            font-family: "DM Mono", monospace;
            font-size: .75rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--accent2);
            margin-bottom: 1.5rem;
            opacity: 0;
            animation: fadeUp .8s .2s forwards;
        }

        .hero-name {
            font-family: "Syne", sans-serif;
            font-size: clamp(3rem, 8vw, 7rem);
            font-weight: 800;
            letter-spacing: -.03em;
            line-height: .95;
            margin-bottom: 1.5rem;
            opacity: 0;
            animation: fadeUp .8s .4s forwards;
        }

        .hero-name .first {
            color: var(--text);
        }

        .hero-name .last {
            color: transparent;
            -webkit-text-stroke: 1.5px var(--accent);
        }

        .typewriter-wrap {
            font-family: "DM Mono", monospace;
            font-size: clamp(.85rem, 2vw, 1.1rem);
            color: var(--text2);
            margin-bottom: 2.5rem;
            height: 1.6em;
            opacity: 0;
            animation: fadeUp .8s .6s forwards;
        }

        .cur {
            display: inline-block;
            width: 2px;
            height: 1em;
            background: var(--accent);
            margin-left: 2px;
            animation: blink 1s step-end infinite;
            vertical-align: middle;
        }

        .hero-desc {
            max-width: 600px;
            font-size: clamp(.88rem, 1.6vw, 1rem);
            color: var(--text2);
            line-height: 1.75;
            margin-bottom: 3rem;
            opacity: 0;
            animation: fadeUp .8s .8s forwards;
        }

        .hero-ctas {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: center;
            opacity: 0;
            animation: fadeUp .8s 1s forwards;
        }

        .btn-primary {
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 14px 32px;
            border-radius: 4px;
            font-family: "Syne", sans-serif;
            font-weight: 600;
            font-size: .85rem;
            letter-spacing: .05em;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all .25s;
            box-shadow: 0 0 30px var(--glow);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 50px var(--glow);
        }

        .btn-ghost {
            background: transparent;
            color: var(--text);
            border: 1px solid var(--border2);
            padding: 14px 32px;
            border-radius: 4px;
            font-family: "Syne", sans-serif;
            font-weight: 600;
            font-size: .85rem;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all .25s;
        }

        .btn-ghost:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .btn-resume {
            background: transparent;
            color: var(--accent2);
            border: 1px solid var(--accent2);
            padding: 14px 32px;
            border-radius: 4px;
            font-family: "Syne", sans-serif;
            font-weight: 600;
            font-size: .85rem;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all .25s;
            box-shadow: 0 0 20px var(--glow2);
        }

        .btn-resume:hover {
            background: var(--accent2);
            color: #fff;
            transform: translateY(-2px);
        }

        .orbit {
            position: absolute;
            border-radius: 50%;
            border: 1px solid var(--border);
            pointer-events: none;
            top: 50%;
            left: 50%;
        }

        .orb1 {
            width: 500px;
            height: 500px;
            animation: orbspin 30s linear infinite;
        }

        .orb1::before {
            content: "";
            position: absolute;
            width: 10px;
            height: 10px;
            background: var(--accent2);
            border-radius: 50%;
            top: -5px;
            left: 50%;
            box-shadow: 0 0 20px var(--accent2);
        }

        .orb2 {
            width: 700px;
            height: 700px;
            border-style: dashed;
            animation: orbspin 50s linear infinite reverse;
        }

        .orb2::before {
            content: "";
            position: absolute;
            width: 7px;
            height: 7px;
            background: var(--accent3);
            border-radius: 50%;
            top: -3.5px;
            left: 50%;
            box-shadow: 0 0 20px var(--accent3);
        }

        .scroll-hint {
            position: absolute;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            opacity: 0;
            animation: fadeUp .8s 1.4s forwards;
        }

        .scroll-hint span {
            font-family: "DM Mono", monospace;
            font-size: .65rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            color: var(--text3);
        }

        .scroll-line {
            width: 1px;
            height: 50px;
            background: linear-gradient(to bottom, var(--accent), transparent);
        }

        section {
            position: relative;
            z-index: 2;
            padding: 70px 5%;
        }

        .section-label {
            font-family: "DM Mono", monospace;
            font-size: .68rem;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: .5rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-label::after {
            content: "";
            flex: 1;
            max-width: 80px;
            height: 1px;
            background: var(--accent);
            opacity: .4;
        }

        .section-title {
            font-family: "Syne", sans-serif;
            font-size: clamp(1.8rem, 4vw, 3rem);
            font-weight: 800;
            letter-spacing: -.03em;
            line-height: 1.05;
            margin-bottom: 2rem;
        }

        .section-divider {
            width: 100%;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--border2), transparent);
            max-width: 1200px;
            margin: 0 auto;
        }

        #about {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 80px;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
        }

        .avatar-wrap {
            display: flex;
            justify-content: center;
        }

        .avatar-ring {
            width: 260px;
            height: 260px;
            border-radius: 50%;
            border: 2px solid var(--border2);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .avatar-star-orbit {
            position: absolute;
            width: 340px;
            height: 340px;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            animation: spinstar 15s linear infinite;
            pointer-events: none;
        }

        .avatar-star {
            position: absolute;
            top: -9px;
            left: 50%;
            transform: translateX(-50%) rotate(45deg);
        }

        @keyframes spinstar {
            from { transform: translate(-50%, -50%) rotate(-45deg); }
            to { transform: translate(-50%, -50%) rotate(315deg); }
        }

        .avatar-ring::before {
            content: "";
            position: absolute;
            inset: -20px;
            border-radius: 50%;
            border: 1px dashed var(--border2);
            animation: spin 20s linear infinite;
        }

        .avatar-ring::after {
            content: "";
            position: absolute;
            inset: -40px;
            border-radius: 50%;
            border: 1px solid transparent;
            border-top-color: var(--accent);
            animation: spin 15s linear infinite reverse;
        }

        .avatar-initials {
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--bg3), var(--bg2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: "Syne", sans-serif;
            font-size: 4rem;
            font-weight: 800;
            color: var(--accent);
            border: 1px solid var(--border2);
            box-shadow: 0 0 60px var(--glow);
        }

        .about-intro {
            font-size: .95rem;
            line-height: 1.75;
            color: var(--text2);
            margin-bottom: .9rem;
        }

        .about-intro strong {
            color: var(--text);
            font-weight: 600;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: .75rem;
            margin-top: 1.25rem;
        }

        .stat {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1rem;
            transition: border-color .2s, transform .2s;
        }

        .stat:hover {
            border-color: var(--accent);
            transform: translateY(-3px);
        }

        .stat-num {
            font-family: "Syne", sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--accent);
        }

        .stat-lbl {
            font-family: "DM Mono", monospace;
            font-size: .65rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--text3);
            margin-top: 2px;
        }

        #skills {
            max-width: 1200px;
            margin: 0 auto;
        }

        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .sg {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.2rem;
            transition: border-color .3s, transform .3s;
        }

        .sg:hover {
            border-color: var(--accent);
            transform: translateY(-4px);
        }

        .sg-title {
            font-family: "DM Mono", monospace;
            font-size: .7rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            color: var(--accent2);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .tag {
            font-family: "DM Mono", monospace;
            font-size: .72rem;
            padding: 4px 12px;
            border-radius: 3px;
            background: var(--surface2);
            border: 1px solid var(--border);
            color: var(--text2);
            transition: all .2s;
            cursor: default;
        }

        .tag:hover {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

        #experience {
            max-width: 1100px;
            margin: 0 auto;
            overflow: visible;
        }

        .solar-wrap {
            width: 100%;
            overflow-x: auto;
            overflow-y: visible;
